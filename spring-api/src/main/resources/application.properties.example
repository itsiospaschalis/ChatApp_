# Spring Boot Application Configuration
# Copy this file to application.properties and update with your values

spring.application.name=spring-api

# Logging Configuration
logging.level.app.chat.springapi=DEBUG
logging.level.org.springframework.security=DEBUG

# Database Configuration
# Update these values to match your PostgreSQL setup
spring.datasource.url=jdbc:postgresql://localhost:5434/postgres
spring.datasource.username=postgres
spring.datasource.password=YOUR_POSTGRES_PASSWORD_HERE

# JPA Configuration
spring.jpa.show-sql=true
spring.jpa.hibernate.ddl-auto=update

# Groq API Configuration
# Get your API key from: https://console.groq.com/keys
# Option A: Set env var LLMS_GROQ_KEY before running (recommended - never committed)
# Option B: Copy to application-local.properties and add your key there (add to .gitignore)
llms.groq.key=${LLMS_GROQ_KEY}

# Server Configuration (optional)
# server.port=8080

